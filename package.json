{
  "name": "openlog",
  "version": "1.0.1",
  "description": "OpenLog — Structured logging platform with MCP tools for AI agents and a browser dashboard",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "openlog": "bin/openlog"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bootstrap": {
      "import": "./dist/bootstrap.js",
      "types": "./dist/bootstrap.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js",
      "types": "./dist/mcp/server.d.ts"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node --experimental-sqlite --import tsx --watch src/index.ts",
    "build:backend": "tsc",
    "build:frontend": "node scripts/build-frontend.mjs",
    "copy:frontend": "node scripts/copy-frontend.mjs",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "node --experimental-sqlite dist/index.js",
    "lint": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "openlog",
    "logging",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "dashboard",
    "hono",
    "sqlite"
  ],
  "author": "codeintheopen",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/bb010/openlog.git"
  },
  "bugs": {
    "url": "https://github.com/bb010/openlog/issues"
  },
  "homepage": "https://github.com/bb010/openlog",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
